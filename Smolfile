image = "debian:bookworm-slim"
workdir = "/app"
net = true

env = [
    "DEBIAN_FRONTEND=noninteractive",
    "LLM_URL=http://172.16.0.1:8080/v1/chat/completions",
    "LLM_MODEL=gemma-4",
    "BROWSER_BIN=/app/bin/browser_skill",
    "CHROME_BIN=/usr/bin/chromium",
]

[dev]
volumes = [
    "./agent:/app/agent",
    "./browser:/app/browser",
    "./bin:/app/bin:ro",
    "./scripts:/app/scripts:ro",
]
